# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexnote

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend URL (used for invitation links and CORS) ───────────────────────
FRONTEND_URL=https://yournexnote.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, list your Vercel URL
# AND any Vercel preview URLs you want to allow.
CORS_ORIGINS=https://yournexnote.com

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Per nexnote-ratelimit-fix.md:
#   - In production, auth limiter (login/register) is strict; refresh is relaxed.
#   - In development (NODE_ENV !== 'production'), every limiter is bumped to a
#     very high value so local testing with multiple accounts on 127.0.0.1
#     never trips 429.
#   - skipSuccessfulRequests: true on /login + /register → only FAILED logins
#     count against the budget.
#
# Round 4 (rate-limit increase): defaults bumped to give normal-use headroom:
#   - Global:  2000 / 15min  (was 500 — creating notes + toggling todos +
#                             switching tabs fire many API calls)
#   - Auth:     100 / 15min  (was 50  — still blocks brute-force)
#   - Refresh:  500 / 15min  (was 200 — auto-fired by frontend)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_MAX=100
REFRESH_RATE_LIMIT_MAX=500

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Email — Gmail SMTP (Nodemailer) ─────────────────────────────────────────
# SECURITY: NEVER commit real values. Use a Gmail App Password — NOT your
# regular Gmail password.
#
# Setup:
#   1. Go to https://myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search "App Passwords" → create one for "NexNote"
#   4. Copy the 16-char password, REMOVE SPACES, set as SMTP_PASS below
#   5. Also set these same values on Render (Dashboard → Environment)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional — leave blank to use Gmail defaults
SMTP_HOST=
SMTP_PORT=

# Sender display name (optional — defaults to "NexNote <SMTP_USER>")
EMAIL_FROM=
EMAIL_REPLY_TO=
