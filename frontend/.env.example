# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy to .env and fill in your values.

# API URL — leave EMPTY in dev (Vite proxy forwards /api → localhost:5001).
# In PRODUCTION (Vercel), set this to your Render backend URL with /api suffix:
#   VITE_API_URL=https://nexnote-api.onrender.com/api
#
# This MUST be set on Vercel (Settings → Environment Variables) — otherwise
# the frontend will try relative /api which won't work cross-origin.

# Local development (Vite proxy handles /api → http://localhost:5001):
# VITE_API_URL=

# Production (set on Vercel):
VITE_API_URL=https://nexnote-api.onrender.com/api
